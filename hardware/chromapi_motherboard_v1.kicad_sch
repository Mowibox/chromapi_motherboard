	(text "\"chromapi_motherboard\" is a dedicated control HAT designed \nto manage the high-speed motion, power distribution, and sensor \nintegration required for the quadruped robot Chromapi."
		(exclude_from_sim no)
		(at 14.986 24.638 0)
		(effects
			(font
				(size 2.0066 2.0066)
				(thickness 0.4013)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "abbc3a21-8cbc-46fb-8f78-d46ae3ce4098")
	)
	(text "Date"
		(exclude_from_sim no)
		(at 128.27 29.21 0)
		(effects
			(font
				(size 2.0066 2.0066)
			)
			(justify left bottom)
		)
		(uuid "adf2ce3f-da17-40d5-a1de-7bd07a2a2904")
	)
	(text "List of devices:\n[Core Logic] \n- STM32G431KBT6 (MCU) & Raspberry Pi\n[Motion Control] \n- SN74LVC1G126 & SN74LVC1G125 for servo communication\n[Power System] \n- TPS51388 (5V DC-DC converter), LD39050 (3.3V LDO)\nand INA226 (I2C Power Monitor)\n[Battery Management] \n- CN3302 (USB-C Charger) and HY2120 (BMS)\n[Sensors] \n- BMI088 6-DOF IMU and 4x Contact switches \n[Audio & Signal] \n- MAX98357A (I2S Amplifier), ICS-43434 (I2S Microphone),\nand SN74AHCT1G125 (LED level shifter)"
		(exclude_from_sim no)
		(at 13.462 173.736 0)
		(effects
			(font
				(size 2.0066 2.0066)
			)
			(justify left)
		)
		(uuid "cbec26e6-ec45-4406-9f0a-5cc6fe36f112")
	)
